<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Parolni tiklash | QR Restoran</title>
  <link rel="stylesheet" href="/public/css/login.css"/>
</head>
<body>
  <div class="page">
    <div class="left">
      <div class="left-pattern"></div>
      <div class="brand">
        <div class="brand-icon">🍽</div>
        <h1>QR Menyu</h1>
        <div class="brand-divider"></div>
        <p>Parolingizni tiklash uchun email kiriting</p>
      </div>
    </div>
    <div class="right">
      <div class="card">
        <div class="card-header">
          <h2>Parolni tiklash</h2>
          <p>Email manzilingizni kiriting</p>
        </div>

        {{#if message}}
          <div class="alert-success" style="background:#e8f5e8;border:1px solid #c0dd97;color:#3b6d11;padding:10px 14px;border-radius:8px;font-size:13px;margin-bottom:1rem;">
            {{message}}
          </div>
        {{/if}}
        {{#if error}}
          <div class="error-msg">{{error}}</div>
        {{/if}}

        <form action="/api/auth/forgot-password" method="POST">
          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" placeholder="ex@gmail.com" required/>
          </div>
          <button type="submit" class="btn-submit">Yuborish</button>
        </form>

        <div class="card-footer">
          <a href="/login">← Kirish sahifasiga qaytish</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>