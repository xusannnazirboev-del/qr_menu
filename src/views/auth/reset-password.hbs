<!DOCTYPE html>
<html lang="uz">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Yangi parol | QR Restoran</title>
  <link rel="stylesheet" href="/public/css/login.css"/>
</head>
<body>
  <div class="page">
    <div class="left">
      <div class="left-pattern"></div>
      <div class="brand">
        <div class="brand-icon">🍽</div>
        <h1>QR Menyu</h1>
        <div class="brand-divider"></div>
        <p>Yangi parol o'rnating</p>
      </div>
    </div>
    <div class="right">
      <div class="card">
        <div class="card-header">
          <h2>Yangi parol</h2>
          <p>Yangi parolingizni kiriting</p>
        </div>

        {{#if error}}
          <div class="error-msg">{{error}}</div>
        {{/if}}

        <form action="/api/auth/reset-password{{queryString}}" method="POST">
          <div class="form-group">
            <label for="password">Yangi parol</label>
            <input type="password" id="password" name="password"
              placeholder="••••••••" minlength="6" required/>
          </div>
          <div class="form-group">
            <label for="confirmPassword">Parolni tasdiqlang</label>
            <input type="password" id="confirmPassword" name="confirmPassword"
              placeholder="••••••••" minlength="6" required/>
          </div>
          <button type="submit" class="btn-submit">Saqlash</button>
        </form>

        <div class="card-footer">
          <a href="/login">← Kirish sahifasiga qaytish</a>
        </div>
      </div>
    </div>
  </div>
</body>
</html>